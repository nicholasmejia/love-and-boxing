[ext_resource type="Script" path="res://scripts/game/dialogue_answer.gd" id="2_answer"]

[sub_resource type="Resource" id="ans_right"]
script = ExtResource("2_answer")
text = "I’ll trust the glove kiss but not the punch."
outcome = 2
reaction_text = "Smart! Trust the cute! Distrust the violence! Wait — that IS the strategy!"

[sub_resource type="Resource" id="ans_neutral"]
script = ExtResource("2_answer")
text = "That’s a nice ritual."
outcome = 1
reaction_text = "Polite. Acceptable. Defensive guard maintained."

[sub_resource type="Resource" id="ans_wrong"]
script = ExtResource("2_answer")
text = "Maybe I should kiss the gloves before they hit me."
outcome = 0
reaction_text = "Oh PLEASE. The gloves do not consent to that."

[resource]
script = ExtResource("1_prompt")
body_text = "Minty pauses to kiss her glove, then immediately throws it. “Don’t read into that. It’s a ritual. Every champion has one. Mine just happens to be cute.”"
answers = Array[Resource]([SubResource("ans_right"), SubResource("ans_neutral"), SubResource("ans_wrong")])
